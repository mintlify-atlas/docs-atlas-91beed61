  "keyFeatures": [
    "Fully sandboxed execution with zero system calls",
    "In-memory Virtual Filesystem with Unix directory structure",
    "28 built-in bash-like commands (grep, sed, find, jq, etc.)",
    "Bash-compatible syntax: pipes, redirections, &&, ||, subshells",
    "Host directory mounts with read-only and read-write modes",
    "Interactive REPL with readline history and Ctrl-C/D support",
    "Script execution from files or stdin",
    "Multi-user support with isolated home directories"
  ],
  "publicApiSurface": [
    "nash (interactive REPL)",
    "nash <script.sh> (script execution)",
    "nash -c <command> (one-shot command)",
    "nash -s (read from stdin)",
    "nash -U <user> (set username)",
    "nash -C <path> (set working directory)",
    "nash -E <KEY=VALUE> (set env vars)",
    "nash -B <host:vfs> (mount directory)",
    "nash --bind-ro <host:vfs> (mount read-only)",
    "nash -e (errexit mode)",
    "nash -u (nounset mode)",
    "nash -x (xtrace mode)",
    "nash -v (verbose mode)",
    "nash --rcfile <file> (custom rc file)",
    "nash --norc (skip rc files)",
